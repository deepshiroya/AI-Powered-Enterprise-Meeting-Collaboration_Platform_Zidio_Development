# ==============================================================================
# IntellMeet - Master Gitignore File
# ==============================================================================

# Node.js dependencies
node_modules/
jspm_packages/
web_modules/

# Build & compilation outputs
dist/
build/
out/
client/dist/
client/build/
server/dist/
server/build/
.next/
.nuxt/

# Environment configurations (Keep sensitive variables secret!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# Logs and debugging traces
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Server temporary files & uploads
uploads/
temp/
tmp/
*.tmp
*.bak
server/src/uploads/
server/uploads/

# Vite, Parcel & build tooling caches
.vite/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache
.tsbuildinfo

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs & Editor configurations
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvsca
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# Test coverage & performance metrics
coverage/
.nyc_output/
.clinic/
.pm2/

# Package manager lock files (optional exclusion override)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
